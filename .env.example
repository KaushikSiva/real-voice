# Local voice MVP defaults.
# Copy to .env if you want scripts/run_mvp.sh to load these automatically.

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
CSM_MODEL_ID=sesame/csm-1b

# Server/UI defaults. On a public VM use HOST=0.0.0.0, or HOST=127.0.0.1
# when running behind Caddy/Nginx.
HOST=127.0.0.1
PORT=8000

# Mac default is auto/MPS. CUDA VMs should override these.
TTS_DEVICE=auto
TTS_DTYPE=float16
WHISPER_DEVICE=auto
WHISPER_MODEL=base

# Low-latency spoken response defaults.
AUTO_WARMUP=1
MAX_TTS_CHUNKS=1
CSM_MAX_NEW_TOKENS=80
MAX_SPOKEN_WORDS=10
REFERENCE_SECONDS=3

# Structured output keeps filler words out of the generated answer text.
STRUCTURED_VOICE_OUTPUT=1

# Reuse the last generated assistant audio as CSM context. Set to 0 if you
# prefer lower latency over smoother prosody.
CSM_AUDIO_CONTEXT_TURNS=1

# Cached fillers are pre-generated after a voice is saved. The auto list can
# name exact clips or prefixes such as "sure" to rotate sure_1/sure_2/sure_3.
CANNED_FILLERS_ENABLED=1
CANNED_FILLERS_AUTO_BUILD=1
CANNED_FILLERS="sure_1=Sure.|sure_2=Yeah.|sure_3=Yep.|okay_1=Okay.|okay_2=Alright.|got_it_1=Got it.|hmm_1=Hmm.|hmm_2=Let me think.|one_sec_1=One sec.|sorry_1=Sorry.|cough_1=Cough.|sneeze_1=Achoo."
CANNED_AUTO_FILLERS=sure,okay,hmm,got_it,one_sec
CANNED_MAX_NEW_TOKENS=48
CANNED_TRAILING_SILENCE_MS=180

# Helps with CSM/Mimi and MPS operator gaps on macOS.
NO_TORCH_COMPILE=1
PYTORCH_ENABLE_MPS_FALLBACK=1
